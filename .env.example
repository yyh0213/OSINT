# ============================================================
#  OSINT Dashboard 환경 변수 설정 파일
#  cp .env.example .env 후 실제 값을 채워주세요
# ============================================================

# [필수] OpenRouter AI API 키
OPENROUTER_API_KEY=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

# [필수] Qdrant / Ollama가 돌아가는 서버 IP
DB_IP=192.168.45.80

# [선택] Discord 알림 (없으면 알림 비활성화)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# DISCORD_USER_ID=123456789012345678

# [선택] Discord 알림에 포함될 대시보드 접속 주소
#  - 로컬: http://localhost:8000
#  - Unraid: http://192.168.45.80:1002
DASHBOARD_URL=http://localhost:8000

# [선택] 보고서 저장 경로 (컨테이너 내부 경로, 기본값 그대로 두면 됨)
REPORT_DIR=/app/OSINT_REPORT
